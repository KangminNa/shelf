{
  "name": "shelf",
  "version": "0.1.0",
  "description": "A lightweight, modular home server framework. Define your data, write your logic, design your pages — Shelf handles everything else.",
  "keywords": [
    "home-server",
    "modular",
    "framework",
    "self-hosted",
    "plugin",
    "dashboard",
    "personal-server"
  ],
  "author": "Kangmin Na",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kangmin/shelf"
  },
  "workspaces": [
    "core",
    "shared",
    "plugins/*"
  ],
  "scripts": {
    "dev": "tsx watch core/src/index.ts",
    "build": "npm run build --workspaces",
    "start": "node core/dist/index.js",
    "create": "tsx core/src/cli/create-module.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
